ASSEMBLYAI_API_KEY=replace-with-your-assemblyai-key
OPENAI_API_KEY=replace-with-your-openai-key
OPENAI_MODEL=gpt-5.3

ASSEMBLYAI_STREAMING_URL=wss://streaming.assemblyai.com/v3/ws
ASSEMBLYAI_STREAMING_MODEL=u3-rt-pro
ASSEMBLYAI_SAMPLE_RATE=16000
ASSEMBLYAI_FORMAT_TURNS=true
ASSEMBLYAI_MIN_TURN_SILENCE_MS=700
ASSEMBLYAI_MAX_TURN_SILENCE_MS=1600

INGRESS_CHUNK_SECONDS=0.16
TRANSLATION_CONTEXT_SIZE=4
OPENAI_TIMEOUT=20

# Optional. Use these if Railway/YouTube blocks extraction.
YTDLP_PROXY_URL=
YTDLP_COOKIES=
YTDLP_COOKIES_B64=
YTDLP_COOKIES_FILE=
